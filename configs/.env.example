# 应用配置
APP_ENV=development
APP_NAME=chatgoo
HTTP_PORT=8000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=chat
DB_PASSWORD=chat123
DB_NAME=chatapp
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300s

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-key-change-in-prod
JWT_EXPIRE_HOURS=72

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# WebSocket
WS_READ_BUFFER_SIZE=10240
WS_WRITE_BUFFER_SIZE=10240
WS_PING_INTERVAL=30s
